# Copy this file to .env and fill in the values before running locally.
# .env is gitignored — never commit real secrets.

# PostgreSQL connection string — spin up a local Postgres or use Neon/Supabase free tier
DATABASE_URL=postgresql://postgres:password@localhost:5432/linguaplay

# Clerk keys — create a free app at https://clerk.com and copy the keys from the dashboard
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Same publishable key, exposed to the Vite frontend
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Arbitrary secret used for session signing (any long random string is fine)
SESSION_SECRET=change-me-to-a-long-random-string
